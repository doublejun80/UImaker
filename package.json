{
  "name": "uiverse-monorepo",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "corepack pnpm --filter @uiverse/web dev",
    "build": "corepack pnpm -r build",
    "test": "vitest run",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
