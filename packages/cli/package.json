{
  "name": "@uiverse/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "uiverse": "./dist/bin.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@uiverse/exporter": "workspace:*",
    "@uiverse/schema": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
